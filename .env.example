# Copy to .env and fill in. .env is gitignored. Load via python-dotenv.
# Phase 0/1 needs NONE of these — yfinance and SEC EDGAR require no key.

# --- Free, recommended ---
# FRED (macro series for Two Sigma / Citadel rate-sensitivity). Free key:
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# SEC EDGAR requires no key, but the fair-access policy requires a descriptive
# User-Agent of the form "Name email". Set yours here (used by the EDGAR provider).
SEC_EDGAR_USER_AGENT=stock-observer your-email@example.com

# --- Paid upgrades (later phases — leave blank until you subscribe) ---
# Financial Modeling Prep Premium ($59/mo) — deep fundamentals/estimates/ETF (Phase 4+).
FMP_API_KEY=
# Tiingo Power / Polygon Starter — clean adjusted prices / intraday (optional).
TIINGO_API_KEY=
POLYGON_API_KEY=

# --- Taiwan (Phase 6) ---
# FinMind — free 600 req/hr when registered; token only needed for higher tiers.
FINMIND_TOKEN=

# --- OPTIONAL: AI persona reports (Phase 4+) ---
# Only required if you enable the optional analyst-persona narrative layer.
# The quant core works fully without this.
ANTHROPIC_API_KEY=
